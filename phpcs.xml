<?xml version="1.0"?>
<ruleset name="Fullworks Simple Setup for Amazon SES">
    <description>Coding standards for Fullworks Simple Setup for Amazon SES WordPress plugin</description>

    <!-- What to scan -->
    <file>./fullworks-simple-setup-for-amazon-ses</file>

    <!-- Exclude vendor directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- How to scan -->
    <arg value="sp"/> <!-- Show progress and sniff codes -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="parallel" value="8"/>
    <arg name="extensions" value="php"/>

    <!-- Rules: WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <!-- Text domain for I18n checks -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="fullworks-simple-setup-for-amazon-ses"/>
            </property>
        </properties>
    </rule>

    <!-- Minimum supported WordPress version -->
    <config name="minimum_supported_wp_version" value="5.0"/>

    <!-- PHP version check -->
    <config name="testVersion" value="8.2-8.4"/>

    <!-- Use WordPress PHP Compatibility -->
    <rule ref="PHPCompatibilityWP"/>
</ruleset>
